# Auto-normalize line endings. Overrides below are authoritative.
* text=auto

*.cs text eol=crlf
*.csproj text eol=crlf
*.props text eol=crlf
*.targets text eol=crlf
*.sln text eol=crlf
*.json text eol=crlf
*.md text eol=crlf
*.ps1 text eol=crlf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf

*.nupkg binary
*.snupkg binary
*.png binary
*.ico binary

# Linguist hints: don't let generated / infra files dominate repo stats.
artifacts/**    linguist-generated=true
**/bin/**       linguist-generated=true
**/obj/**       linguist-generated=true
samples/**      linguist-documentation=true
benchmarks/**   linguist-documentation=true
.github/**      linguist-vendored=true
